<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    android:scrollbarStyle="outsideOverlay">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="40dp">

        <!-- ======================================= -->
        <!-- ヘッダー -->
        <!-- ======================================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="36dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✂️ ClipScout"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="@color/primary_light"
                android:letterSpacing="0.02"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="スクリーンショット → スカウトDM 自動生成"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp"
                android:letterSpacing="0.01" />
        </LinearLayout>

        <!-- ======================================= -->
        <!-- 権限不足バナー（全権限が揃ったら非表示） -->
        <!-- ======================================= -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tvPermissionsBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#2A1515"
            app:cardElevation="4dp"
            app:strokeColor="#FF4444"
            app:strokeWidth="1dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:text="⚠️ 必要な権限が不足しています。下の「権限ステータス」から付与してください。"
                android:textColor="#FF8888"
                android:textSize="13sp" />

        </com.google.android.material.card.MaterialCardView>

        <!-- ======================================= -->
        <!-- サービスON/OFF カード -->
        <!-- ======================================= -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.ClipScout.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📡 監視サービス"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvServiceStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔴 停止中"
                        android:textSize="13sp"
                        android:textColor="@color/status_inactive"
                        android:layout_marginTop="3dp" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchService"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/primary"
                    app:trackTint="@color/surface_variant" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ======================================= -->
        <!-- Gemini APIキー カード -->
        <!-- ======================================= -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.ClipScout.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔑 Gemini APIキー"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Google AI Studio で取得したAPIキーを貼り付けてください"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        style="@style/Widget.ClipScout.TextInputLayout">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etApiKey"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="AIzaSy..."
                            android:inputType="textPassword"
                            android:fontFamily="monospace"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToggleApiKeyVisibility"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="表示"
                        android:layout_marginStart="10dp"
                        style="@style/Widget.ClipScout.Button.Outlined" />

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ======================================= -->
        <!-- システムプロンプト カード -->
        <!-- ======================================= -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.ClipScout.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📝 システムプロンプト"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResetPrompt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="リセット"
                        android:textColor="@color/text_secondary"
                        style="@style/Widget.MaterialComponents.Button.TextButton" />

                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.ClipScout.TextInputLayout">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSystemPrompt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="スカウトDM生成のプロンプトを入力..."
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="7"
                        android:maxLines="20"
                        android:gravity="top|start"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ======================================= -->
        <!-- 設定保存ボタン -->
        <!-- ======================================= -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="💾 設定を保存する"
            android:textSize="16sp"
            android:layout_marginBottom="20dp"
            style="@style/Widget.ClipScout.Button.Primary" />

        <!-- ======================================= -->
        <!-- 権限ステータス カード -->
        <!-- ======================================= -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.ClipScout.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔐 権限ステータス"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp" />

                <!-- メディア読み取り権限 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="メディア読み取り"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="READ_MEDIA_IMAGES"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvPermMediaStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="❌ 未付与"
                        android:textColor="@color/status_inactive"
                        android:textSize="13sp"
                        android:gravity="end" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="10dp" />

                <!-- 通知権限 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="通知の表示"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="POST_NOTIFICATIONS"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvPermNotifStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="❌ 未付与"
                        android:textColor="@color/status_inactive"
                        android:textSize="13sp"
                        android:gravity="end" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="10dp" />

                <!-- オーバーレイ権限 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="他アプリの上に表示"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SYSTEM_ALERT_WINDOW（クリップボード書き込み必須）"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvPermOverlayStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="❌ 未付与"
                        android:textColor="@color/status_inactive"
                        android:textSize="13sp"
                        android:gravity="end" />
                </LinearLayout>

                <!-- 権限リクエストボタン（メディア＋通知） -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRequestRuntimePermissions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📋 メディア・通知の権限を要求"
                    android:layout_marginBottom="8dp"
                    style="@style/Widget.ClipScout.Button.Outlined" />

                <!-- オーバーレイ権限設定画面へ -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenOverlaySettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🪟 「他のアプリの上に表示」を設定する"
                    style="@style/Widget.ClipScout.Button.Outlined" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- フッター -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Powered by Gemini 1.5 Flash"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:gravity="center"
            android:paddingTop="8dp" />

    </LinearLayout>
</ScrollView>
